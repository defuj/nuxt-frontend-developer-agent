{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "nuxt": {
      "type": "remote",
      "url": "https://nuxt.com/mcp",
      "enabled": true,
      "description": "Nuxt documentation, blog posts, and deployment guides"
    },
    "nuxt-ui": {
      "type": "remote",
      "url": "https://ui.nuxt.com/mcp",
      "enabled": true,
      "description": "Nuxt UI component documentation and examples"
    },
    "figma": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-figma"],
      "env": {
        "FIGMA_ACCESS_TOKEN": "${FIGMA_ACCESS_TOKEN}"
      },
      "enabled": false,
      "description": "Figma design file access (requires FIGMA_ACCESS_TOKEN)"
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-playwright"],
      "enabled": true,
      "description": "Browser automation and E2E testing with Playwright"
    }
  },
  "agent": {
    "frontend": {
      "description": "Expert frontend developer for Nuxt.js, Vue, and modern web technologies with MCP integration",
      "mode": "subagent",
      "prompt": "{file:.opencode/agents/frontend-developer.md}",
      "model": "anthropic/claude-sonnet-4-20250514",
      "temperature": 0.4,
      "color": "#3b82f6",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "ask",
          "npm *": "allow",
          "pnpm *": "allow",
          "bun *": "allow",
          "yarn *": "allow",
          "git status": "allow",
          "git diff": "allow",
          "git log*": "allow",
          "npx playwright*": "allow"
        },
        "webfetch": "allow",
        "skill": {
          "*": "allow"
        },
        "mcp": {
          "nuxt": "allow",
          "nuxt-ui": "allow",
          "figma": "ask",
          "playwright": "allow"
        }
      }
    }
  },
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"]
}
